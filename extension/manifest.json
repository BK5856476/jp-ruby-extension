{
    "manifest_version": 3,
    "name": "jp-ruby-extension",
    "version": "1.0",
    "description": "选中文本，请求本地 NLP 服务",
    "permissions": ["storage"],
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ]
        }
    ]
}